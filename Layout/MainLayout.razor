@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar @(isNavCompact ? "is-compact" : null)">
        <NavMenu CompactModeChanged="SetNavCompact" />
    </div>
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private bool isNavCompact;

    private void SetNavCompact(bool isCompact) => isNavCompact = isCompact;
}
